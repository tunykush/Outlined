{
  "name": "easy-cite-generator-ts",
  "version": "1.0.0",
  "description": "TypeScript citation generator following RMIT Easy Cite APA 7th rules",
  "type": "module",
  "scripts": {
    "build:client": "esbuild src/client/main.ts --bundle --outfile=public/app.js --format=iife --target=es2020 --sourcemap",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "watch:client": "esbuild src/client/main.ts --bundle --outfile=public/app.js --format=iife --target=es2020 --sourcemap --watch",
    "dev:server": "tsx watch src/server/index.ts",
    "dev": "npm run build:client && npm run dev:server",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.7.2",
    "esbuild": "^0.20.2",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.12.7"
  }
}
