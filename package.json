{
  "name": "outlined",
  "version": "1.0.0",
  "description": "TypeScript citation generator following uploaded RMIT APA 7th and RMIT Harvard guides",
  "type": "module",
  "scripts": {
    "build:client": "esbuild src/client/main.ts --bundle --outfile=public/app.js --format=iife --target=es2020 --sourcemap",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "watch:client": "esbuild src/client/main.ts --bundle --outfile=public/app.js --format=iife --target=es2020 --sourcemap --watch",
    "dev:server": "tsx watch src/server/index.ts",
    "dev": "npm run build:client && npm run dev:server",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test:harvard": "node tests/harvard-golden-smoke.mjs && tsx tests/harvard-metascan-smoke.ts",
    "test:apa": "tsx tests/style-golden-smoke.ts && tsx tests/apa-metascan-smoke.ts",
    "test:reference": "tsx tests/reference-lookup-smoke.ts",
    "test:styles": "tsx tests/style-golden-smoke.ts",
    "test:doi": "tsx tests/extractor-doi-smoke.ts",
    "test:entities": "tsx tests/extractor-entities-smoke.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.0.0",
    "compromise": "^14.15.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsdom": "^29.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.12.7",
    "esbuild": "^0.20.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
